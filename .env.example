# Environment Configuration
# Copy this file to .env and fill in your values

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_BOT_USER_ID=UXXXXXXXXXX

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
MODEL_NAME=llama3.2:3b
OLLAMA_NUM_CTX=3072
OLLAMA_TIMEOUT=600.0

# Optional: OpenWeatherMap API (for get_weather tool)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Optional: Giphy API (for search_gif tool)
# Get free key at: https://developers.giphy.com/
# Uses public beta key if not set (limited)
GIPHY_API_KEY=

# Optional: GitHub Token (for get_github_activity)
# Get at: https://github.com/settings/tokens
# Works without it for public repos
GITHUB_TOKEN=

# Memory & Performance Configuration
MAX_MEMORY=10
MAX_ITERATIONS=3

# Smart Model Routing (automatically uses fast model for simple queries)
SMART_ROUTING_ENABLED=true
FAST_MODEL=tinyllama

# Scheduler Configuration
SCHEDULED_TASKS_FILE=/path/to/scheduled_tasks.json
